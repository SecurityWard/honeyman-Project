# Environment files
.env
.env.local
.env.*.local
*.env

# Local deploy / one-shot scratch scripts — these get fed via `ssh root@vps bash -s < ...`
# and shouldn't be tracked.
.deploy-*.sh

# Logs
logs/
*.log
*.log.*
*.pid

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
venv/
ENV/
env/
.venv

# IDE
.vscode/
.idea/
*.sublime-*

# OS
.DS_Store
Thumbs.db
*.swp
*.swo
*~

# API keys and secrets — match common secret-filename patterns,
# then explicitly re-include source files that handle API keys.
*api_key*
*secret*
*password*
*credentials*
HOSTINGER_API_KEY
!honeyman-v2/**/api_key.py
!honeyman-v2/**/api_key.ts
!honeyman-v2/**/test_api_key*.py
!honeyman-v2/agent/example_config.yaml

# Backup files
*.backup
*.bak
backup/
backups/

# Temporary files
tmp/
temp/
*.tmp
*.temp

# Personal/Conversation files
claude*
conversation*
reminder*

# Data files (except config and JS package manifests)
*.json
!config/*.json
!dashboard/package.json
!config/wifi_whitelist.json
!honeyman-v2/**/package.json
!honeyman-v2/**/package-lock.json
!honeyman-v2/**/tsconfig*.json
*.csv
*.db
!data/malware_hashes.db
*.sqlite

# Cache and threat feeds
cache/
.cache/

# Archives
*.zip
*.tar.gz
*.rar
*.7z

# Node modules (for dashboard)
node_modules/
npm-debug.log*
dashboard/node_modules/

# Build outputs
dist/
build/
*.egg-info/

# Test files
test_*.py
test_*.sh
*.test