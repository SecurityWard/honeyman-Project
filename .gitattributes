# Force LF line endings on files that target Linux at runtime.
# Without this, a clone on Windows + a re-commit would silently CRLF
# the install script, and `bash: ^M: command not found` is a fun thing
# to debug on a sealed Pi at a conference.

*.sh        text eol=lf
*.py        text eol=lf
*.yaml      text eol=lf
*.yml       text eol=lf
*.service   text eol=lf
*.timer     text eol=lf
*.conf      text eol=lf
*.cron      text eol=lf
*.logrotate text eol=lf
Dockerfile  text eol=lf

# Markdown is fine either way; keep it consistent so diffs stay clean.
*.md        text eol=lf
