# Honeyman uptime probe configuration.
#
# Install: copy to /etc/honeyman/healthcheck.env, mode 0600
# (this file is read by the systemd unit as root, so the URL inside
# can be a webhook with a secret token).
#
# After editing:
#     systemctl daemon-reload   # only if you changed the service unit
#     systemctl restart honeyman-healthcheck.service
#     systemctl start honeyman-healthcheck.service   # fire one probe
#     journalctl -u honeyman-healthcheck.service -n 20 --no-pager

# Public base URLs the probe hits. Defaults to the production
# endpoints; override if you're running a different backend/dashboard.
# API_BASE=https://api.honeymanproject.com
# DASH_BASE=https://dashboard.honeymanproject.com

# Per-probe HTTP timeout in seconds.
# TIMEOUT=10

# Notification webhook. The probe POSTs:
#     {"status":"down","host":"<hostname>","detail":"<reason>"}
# Pick whichever your team listens to:
#
#   Discord     https://discord.com/api/webhooks/<id>/<token>
#   Slack       https://hooks.slack.com/services/<id>
#   Generic     anything that accepts POST application/json
#
# Leave commented out to disable webhook notifications — the probe
# still logs failures to syslog and the systemd unit still goes red,
# you just won't get pinged.
# HEALTHCHECK_WEBHOOK=https://discord.com/api/webhooks/XXXXXXX/YYYYYYY
