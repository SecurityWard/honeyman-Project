%% Honeyman Architecture
%% See PROJECT-PLAN.md for the canonical plan.
%% Last updated: 2026-06-24

graph TB
    %% =========================================================
    %% SENSOR (Pi Zero 2 W / Pi 4 — portable, battery-friendly)
    %% =========================================================
    subgraph SENSOR["📡 Sensor (Raspberry Pi)"]
        direction TB

        subgraph DETECTORS["Detection modules"]
            USB[USB Detector<br/>pyudev + 360+ malware hashes<br/>BadUSB / Rubber Ducky / OMG Cable]
            WIFI[WiFi Detector<br/>scapy / iwlist<br/>Evil Twin · Deauth · Pineapple]
            BLE[BLE Detector<br/>bleak / bluetoothctl<br/>Flipper Zero · BLE spam · HID]
            AIRDROP[AirDrop / mDNS<br/>avahi-browse<br/>Service flooding · TXT abuse]
            CANARY[Canary Network Stack<br/>SSH + HTTP honeypots<br/>(toggleable, off by default)]
        end

        RULES[Rule Engine<br/>loads /etc/honeyman/rules/*.yaml<br/>hot-reload on file change]
        LOC[Location Service<br/>GPS → WiFi-positioning → IP<br/>operator-pin override]

        DETECTORS --> RULES
        RULES --> LOC

        TRANSPORT[Transport Layer<br/>HTTPS + API key (default)<br/>MQTT + creds (optional)<br/>SQLite offline buffer]
        LOC --> TRANSPORT

        RULEPULL[Rule Sync Poller<br/>GET /v2/rules every 5 min<br/>writes new/changed YAML to disk]
        RULEPULL -.->|reload| RULES
    end

    %% =========================================================
    %% TRANSPORT
    %% =========================================================
    HTTPS[(HTTPS<br/>POST /v2/threats<br/>POST /v2/heartbeat<br/>GET /v2/rules)]
    MQTT[(MQTT/TLS — optional<br/>honeyman/sensors/{id}/threats<br/>honeyman/sensors/{id}/heartbeat)]

    TRANSPORT -->|default| HTTPS
    TRANSPORT -.->|opt-in| MQTT
    RULEPULL --> HTTPS

    %% =========================================================
    %% VPS BACKEND
    %% =========================================================
    subgraph VPS["☁️ VPS"]
        direction TB

        FASTAPI[FastAPI Backend<br/>POST /v2/sensors/register → API key<br/>POST /v2/threats   (api-key)<br/>POST /v2/heartbeat (api-key)<br/>GET  /v2/rules     (api-key)<br/>GET  /v2/threats   (public)<br/>GET  /v2/sensors   (public)<br/>GET  /v2/analytics/* (public)<br/>WS   /v2/ws        (public)]

        MQTTSUB[MQTT Subscriber<br/>only started if MQTT_OFFERED=true]
        REDIS[(Redis<br/>cache + pub/sub)]
        DB[(Postgres + TimescaleDB<br/>threats hypertable<br/>90d retention<br/>compression after 7d)]
        RULESREPO[(Git: honeyman-rules<br/>backend serves what's checked in)]

        HTTPS --> FASTAPI
        MQTT -.-> MQTTSUB
        MQTTSUB --> DB
        MQTTSUB --> REDIS
        FASTAPI --> DB
        FASTAPI --> REDIS
        FASTAPI --> RULESREPO
    end

    %% =========================================================
    %% PUBLIC DASHBOARD
    %% =========================================================
    subgraph DASH["🌐 Public Dashboard (read-only)"]
        direction TB
        REACT[React + TypeScript SPA<br/>no login, no actions]
        MAP[Leaflet Threat Map<br/>color-coded severity markers<br/>filters: time / sensor / type]
        FEED[Live Event Feed<br/>WebSocket, last 20 threats]
        CHARTS[Charts: trends, top threats, top sensors]
        STATS[Stat cards + sensor list]
        REACT --> MAP
        REACT --> FEED
        REACT --> CHARTS
        REACT --> STATS
    end

    REDIS -->|live threats| FEED
    FASTAPI -->|REST| REACT

    %% =========================================================
    %% Styling
    %% =========================================================
    classDef sensor    fill:#e1f5fe,stroke:#0277bd,color:#000
    classDef transport fill:#fff3e0,stroke:#e65100,color:#000
    classDef backend   fill:#f3e5f5,stroke:#4a148c,color:#000
    classDef storage   fill:#e8f5e8,stroke:#2e7d32,color:#000
    classDef dash      fill:#fce4ec,stroke:#c2185b,color:#000

    class USB,WIFI,BLE,AIRDROP,CANARY,RULES,LOC,TRANSPORT,RULEPULL sensor
    class HTTPS,MQTT transport
    class FASTAPI,MQTTSUB backend
    class REDIS,DB,RULESREPO storage
    class REACT,MAP,FEED,CHARTS,STATS dash
