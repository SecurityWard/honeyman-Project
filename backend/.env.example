# Honeyman Dashboard Backend — environment variables.
# Reads are public; writes use per-sensor API keys (no JWT).

# Application
DEBUG=false
APP_NAME=Honeyman Dashboard API
APP_VERSION=2.0.0

# Server
HOST=0.0.0.0
PORT=8000
WORKERS=4

# Used in onboarding response so sensors know where to POST
PUBLIC_API_BASE_URL=https://api.honeymanproject.com

# CORS Origins (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,https://dashboard.honeymanproject.com

# Database (PostgreSQL + TimescaleDB)
DATABASE_URL=postgresql+asyncpg://honeyman:your-db-password@localhost:5432/honeyman_v2
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10
DATABASE_ECHO=false

# Redis
REDIS_URL=redis://localhost:6379/0
REDIS_CACHE_TTL=300

# MQTT broker (optional — sensors push via HTTPS by default).
# Set MQTT_OFFERED=true to advertise MQTT in onboarding responses and
# start the MQTT subscriber at backend startup.
MQTT_OFFERED=false
MQTT_BROKER_HOST=
MQTT_BROKER_PORT=8883
MQTT_BROKER_USERNAME=
MQTT_BROKER_PASSWORD=
MQTT_USE_TLS=true
MQTT_CA_CERT=

# MQTT Topics (only used if MQTT_OFFERED=true)
MQTT_TOPIC_THREATS=honeyman/sensors/+/threats
MQTT_TOPIC_HEARTBEAT=honeyman/sensors/+/heartbeat
MQTT_TOPIC_CONTROL=honeyman/control/#

# Data Retention
DATA_RETENTION_DAYS=90
CLEANUP_INTERVAL_HOURS=24

# Rule manifest source. If unset, defaults to ../agent/rules — the
# single source of truth for the YAML rules sensors fetch via
# GET /api/v2/rules.
RULES_DIR=

# Geolocation APIs (optional — backend currently does not call these;
# sensors do. See agent/honeyman/services/location_service.py)
GOOGLE_GEOLOCATION_API_KEY=
IP_GEOLOCATION_API_KEY=

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json

# Rate Limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_PER_MINUTE=60

# WebSocket
WS_HEARTBEAT_INTERVAL=30
